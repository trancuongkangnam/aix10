# ===== SUPABASE (database người dùng) =====
# Lấy tại: https://supabase.com → Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== SEPAY (thanh toán) =====
# Đăng ký tại: https://sepay.vn
# API Key lấy tại: Dashboard → Cài đặt → API
SEPAY_API_KEY=your-sepay-api-key
SEPAY_ACCOUNT_NUMBER=your-bank-account-number
SEPAY_BANK_CODE=MB  # MB, VCB, TCB, ACB, v.v.
SEPAY_WEBHOOK_SECRET=your-webhook-secret-key

# ===== APP CONFIG =====
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
NEXT_PUBLIC_APP_NAME=AutoBiz AI

# ===== EMAIL (tùy chọn - gửi email xác nhận) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
